{
  "version": "policy-v1",
  "locale": "ar-ps",

  "intents": {
    "deals": {
      "keywords": ["خصم", "خصومات", "تنزيلات", "عروض", "تخفيض", "سيل", "sale", "off"]
    },

    "budget": {
      "keywords": [
        "قديش", "بكم", "سعره", "كم حقه", "كم سعره",
        "بحدود", "حوالي", "تقريبا", "على قدي", "على قد الايد",
        "راعينا", "ارخص", "رخيص","مش غالي", "مراعاة", "معقول",
        "ما بدي اغلى من", "مش اكثر من", "حده"
      ]
    },

    "premium": {
      "keywords": ["افخم", "احسن", "احسن نوع", "ممتاز", "اصلي", "براند", "مش مهم السعر", "ما بفرق السعر"]
    }
  },

  "session": {
